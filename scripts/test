#!/usr/bin/env bash

BASE_URL="${1:-http://localhost:4004}"
#ENDPOINT="$BASE_URL/odata/v4/workflow-projection"
ENDPOINT="$BASE_URL/workflow"
BUSINESS_KEY="ORDER-$(date +%s)"

read -p "=== 1. Start workflow ==="
RESPONSE=$(curl -s -X POST "$ENDPOINT/startWorkflow" \
  -H "Content-Type: application/json" \
  -d "$(jq -n --arg bk "$BUSINESS_KEY" '{workflowType:"APPROVAL_V1", businessKey:$bk}')")
echo "$RESPONSE" | jq .
WORKFLOW_ID=$(echo "$RESPONSE" | jq -r '.workflowId')

read -p "=== 2. Get state ==="
curl -s -X POST "$ENDPOINT/getWorkflowState" \
  -H "Content-Type: application/json" \
  -d "$(jq -n --arg id "$WORKFLOW_ID" '{workflowId:$id}')" | jq .

read -p "=== 3. Submit ==="
curl -s -X POST "$ENDPOINT/transition" \
  -H "Content-Type: application/json" \
  -d "$(jq -n --arg id "$WORKFLOW_ID" '{workflowId:$id, event:"SUBMIT", payload:"{\"submittedBy\":\"alice\"}"}')" | jq .

read -p "=== 4. Approve ==="
curl -s -X POST "$ENDPOINT/transition" \
  -H "Content-Type: application/json" \
  -d "$(jq -n --arg id "$WORKFLOW_ID" '{workflowId:$id, event:"APPROVE", payload:"{\"approverId\":\"bob\"}"}')" | jq .

read -p "=== 5. Get final state ==="
curl -s -X POST "$ENDPOINT/getWorkflowState" \
  -H "Content-Type: application/json" \
  -d "$(jq -n --arg id "$WORKFLOW_ID" '{workflowId:$id}')" | jq .

read -p "=== 6. History ==="
curl -s "$ENDPOINT/WorkflowHistory?\$filter=workflow_ID%20eq%20'$WORKFLOW_ID'&\$orderby=occurredAt%20asc" | jq .
